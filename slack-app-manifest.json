{
  "display_information": {
    "name": "TacoTime",
    "description": "Celebrate your team with tacos! 🌮 Give recognition, build culture.",
    "background_color": "#f59e0b",
    "long_description": "TacoTime is a fun peer recognition bot that lets team members give virtual tacos to celebrate wins, say thanks, and build a positive team culture. Features include daily taco limits, leaderboards, a rewards shop, and value-based tagging."
  },
  "features": {
    "app_home": {
      "home_tab_enabled": true,
      "messages_tab_enabled": true,
      "messages_tab_read_only_enabled": false
    },
    "bot_user": {
      "display_name": "TacoTime",
      "always_online": true
    },
    "slash_commands": [
      {
        "command": "/tacotime",
        "url": "https://heytaco-all-events.vercel.app/api/slack/commands",
        "description": "TacoTime commands - give tacos, check stats, view leaderboard",
        "usage_hint": "[give @user message | leaderboard | my-tacos | help]",
        "should_escape": false
      },
      {
        "command": "/tt",
        "url": "https://heytaco-all-events.vercel.app/api/slack/commands",
        "description": "TacoTime shortcut - give tacos, check stats, view leaderboard",
        "usage_hint": "[give @user message | leaderboard | my-tacos | help]",
        "should_escape": false
      }
    ]
  },
  "oauth_config": {
    "redirect_urls": [
      "https://heytaco-all-events.vercel.app/api/auth/callback/slack"
    ],
    "scopes": {
      "user": [
        "identity.basic",
        "identity.email",
        "identity.avatar",
        "identity.team"
      ],
      "bot": [
        "app_mentions:read",
        "channels:history",
        "channels:read",
        "chat:write",
        "commands",
        "emoji:read",
        "groups:history",
        "groups:read",
        "im:history",
        "im:read",
        "im:write",
        "mpim:history",
        "mpim:read",
        "reactions:read",
        "team:read",
        "users:read",
        "users:read.email",
        "users.profile:read"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "request_url": "https://heytaco-all-events.vercel.app/api/slack/events",
      "bot_events": [
        "app_mention",
        "message.channels",
        "message.groups",
        "message.im",
        "message.mpim",
        "reaction_added",
        "team_join"
      ]
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": false,
    "token_rotation_enabled": false
  }
}

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id @default(cuid())
  slackId       String   @unique
  teamId        String
  name          String
  displayName   String
  email         String?
  avatarUrl     String?
  isAdmin       Boolean  @default(false)
  isActive      Boolean  @default(true)
  dailyLimit    Int      @default(5)
  totalReceived Int      @default(0)
  totalGiven    Int      @default(0)
  redeemable    Int      @default(0)
  birthday      String?
  workAnniversary String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tacosGiven    Taco[]       @relation("TacoGiver")
  tacosReceived Taco[]       @relation("TacoReceiver")
  redemptions   Redemption[]

  @@index([teamId])
}

model Taco {
  id        String   @id @default(cuid())
  giverId   String
  receiverId String
  amount    Int      @default(1)
  message   String?
  channel   String?
  channelName String?
  teamId    String
  createdAt DateTime @default(now())

  giver     User     @relation("TacoGiver", fields: [giverId], references: [id])
  receiver  User     @relation("TacoReceiver", fields: [receiverId], references: [id])
  tags      TacoTag[]

  @@index([giverId])
  @@index([receiverId])
  @@index([teamId])
  @@index([createdAt])
}

model Tag {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  color       String   @default("#F59E0B")
  teamId      String
  createdAt   DateTime @default(now())

  tacoTags    TacoTag[]

  @@index([teamId])
}

model TacoTag {
  id     String @id @default(cuid())
  tacoId String
  tagId  String

  taco   Taco   @relation(fields: [tacoId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([tacoId, tagId])
}

model Reward {
  id          String   @id @default(cuid())
  title       String
  description String?
  cost        Int
  quantity    Int?
  imageUrl    String?
  type        String   @default("custom") // custom, group, giftcard
  isActive    Boolean  @default(true)
  teamId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  redemptions Redemption[]

  @@index([teamId])
}

model Redemption {
  id        String   @id @default(cuid())
  userId    String
  rewardId  String
  status    String   @default("pending") // pending, fulfilled, cancelled
  teamId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id])
  reward    Reward   @relation(fields: [rewardId], references: [id])

  @@index([userId])
  @@index([teamId])
}

model TeamSettings {
  id              String  @id @default(cuid())
  teamId          String  @unique
  teamName        String?
  dailyTacoLimit  Int     @default(5)
  leaderboardEnabled Boolean @default(true)
  reactionsEnabled   Boolean @default(true)
  giverModeEnabled   Boolean @default(false)
  tacoEmoji       String  @default(":taco:")
  welcomeMessage  String?
  slackBotToken   String?
  slackSigningSecret String?
  slackClientId   String?
  slackClientSecret  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model DailyTacoTracker {
  id        String   @id @default(cuid())
  userId    String
  date      String   // YYYY-MM-DD format
  tacosGiven Int     @default(0)

  @@unique([userId, date])
  @@index([userId])
}
